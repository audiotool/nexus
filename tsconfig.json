{
  "compilerOptions": {
    "target": "esnext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["esnext", "DOM"],
    "types": ["node"],
    "skipLibCheck": true,

    /* Library mode */
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": false,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@utils/*": ["src/utils/*"],
      "@api/*": ["src/api/*"],
      "@entities/*": ["src/entities/*"],
      "@document/*": ["src/document/*"],
      "@gen/*": ["src/gen/audiotool/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
